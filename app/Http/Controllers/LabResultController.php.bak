<?php

namespace App\Http\Controllers;

use App\Models\LabOrder;
use App\Models\LabOrderExam;
use App\Models\LabResult;
use App\Models\Company;
use Illuminate\Http\Request;
use Illuminate\Support\Facades\Auth;
use Barryvdh\DomPDF\Facade\Pdf;

class LabResultController extends Controller
{
    public function __construct()
    {
        $this->middleware('permission:lab-results.print')->only(['printPdf', 'printDoc']);
        $this->middleware('permission:lab-results.create')->only(['create', 'store']);
        $this->middleware('permission:lab-results.edit')->only(['edit', 'update']);
    }

    /**
     * Generar PDF del resultado de un examen
     */
    public function printPdf($orderExamId)
    {
        $orderExam = LabOrderExam::with([
            'order.patient',
            'order.doctor',
            'order.company',
            'exam.category',
            'results.validatedBy',
            'results.processedBy'
        ])->findOrFail($orderExamId);

        $company = $orderExam->order->company ?? Company::first();

        // Obtener información del laboratorio desde configuración o company
        $labInfo = [
            'nombre' => config('laboratorio.informacion.nombre', $company->name ?? 'LABORATORIO CLINICO PRO-MEDIC'),
            'direccion' => $company->addres ?? 'Final Avenida El Calvario, Calle principal, Nahuizalco (Frente a parada de buses del chorro Público)',
            'telefonos' => $company->number_phone ?? '2420-4997 y 6303-3392',
            'horario' => 'Lunes a Sábado de: 7:00 a.m. - 3:00 p.m.',
        ];

        // Determinar qué plantilla usar según el tipo de examen
        $exam = $orderExam->exam;

        // Usar siempre la plantilla genérica universal
        $template = 'laboratory.results.generic-pdf';

        try {
            $pdf = Pdf::loadView($template, [
                'orderExam' => $orderExam,
                'order' => $orderExam->order,
                'patient' => $orderExam->order->patient,
                'doctor' => $orderExam->order->doctor,
                'exam' => $exam,
                'results' => $orderExam->results,
                'company' => $company,
                'labInfo' => $labInfo,
                'valoresReferencia' => $exam->valores_referencia_especificos ?? null,
            ]);

            $pdf->setPaper('Letter', 'portrait');
            $pdf->setOption('isHtml5ParserEnabled', true);
            $pdf->setOption('isRemoteEnabled', true);
            $pdf->setOption('defaultFont', 'Arial');

            $fileName = 'resultado_' . str_replace(' ', '_', $orderExam->exam->nombre) . '_' . date('Y-m-d') . '.pdf';

            return $pdf->stream($fileName);

        } catch (\Exception $e) {
            \Log::error('Error generando PDF de resultado: ' . $e->getMessage());
            return back()->with('error', 'Error al generar el PDF: ' . $e->getMessage());
        }
    }

    /**
     * Descargar PDF del resultado de un examen
     */
    public function downloadPdf($orderExamId)
    {
        $orderExam = LabOrderExam::with([
            'order.patient',
            'order.doctor',
            'order.company',
            'exam.category',
            'results.validatedBy',
            'results.processedBy'
        ])->findOrFail($orderExamId);

        $company = $orderExam->order->company ?? Company::first();

        $labInfo = [
            'nombre' => config('laboratorio.informacion.nombre', $company->name ?? 'LABORATORIO CLINICO PRO-MEDIC'),
            'direccion' => $company->addres ?? 'Final Avenida El Calvario, Calle principal, Nahuizalco (Frente a parada de buses del chorro Público)',
            'telefonos' => $company->number_phone ?? '2420-4997 y 6303-3392',
            'horario' => 'Lunes a Sábado de: 7:00 a.m. - 3:00 p.m.',
        ];

        $exam = $orderExam->exam;

        // Usar siempre la plantilla genérica universal
        $template = 'laboratory.results.generic-pdf';

        try {
            $pdf = Pdf::loadView($template, [
                'orderExam' => $orderExam,
                'order' => $orderExam->order,
                'patient' => $orderExam->order->patient,
                'doctor' => $orderExam->order->doctor,
                'exam' => $exam,
                'results' => $orderExam->results,
                'company' => $company,
                'labInfo' => $labInfo,
                'valoresReferencia' => $exam->valores_referencia_especificos ?? null,
            ]);

            $pdf->setPaper('Letter', 'portrait');
            $pdf->setOption('isHtml5ParserEnabled', true);
            $pdf->setOption('isRemoteEnabled', true);
            $pdf->setOption('defaultFont', 'Arial');

            $fileName = 'resultado_' . str_replace(' ', '_', $orderExam->exam->nombre) . '_' . date('Y-m-d') . '.pdf';

            return $pdf->download($fileName);

        } catch (\Exception $e) {
            \Log::error('Error descargando PDF de resultado: ' . $e->getMessage());
            return back()->with('error', 'Error al descargar el PDF: ' . $e->getMessage());
        }
    }

    /**
     * Generar y descargar DOC del resultado de un examen
     * Nota: Requiere instalar PhpOffice/PhpWord: composer require phpoffice/phpword
     */
    public function printDoc($orderExamId)
    {
        // Verificar si PhpWord está disponible
        if (!class_exists(\PhpOffice\PhpWord\PhpWord::class)) {
            return back()->with('error', 'La funcionalidad de exportación a Word requiere instalar PhpOffice/PhpWord. Ejecute: composer require phpoffice/phpword');
        }

        $orderExam = LabOrderExam::with([
            'order.patient',
            'order.doctor',
            'order.company',
            'exam',
            'results.validatedBy',
            'results.processedBy'
        ])->findOrFail($orderExamId);

        $company = $orderExam->order->company ?? Company::first();

        $labInfo = [
            'nombre' => config('laboratorio.informacion.nombre', $company->name ?? 'LABORATORIO CLINICO PRO-MEDIC'),
            'direccion' => $company->addres ?? 'Final Avenida El Calvario, Calle principal, Nahuizalco (Frente a parada de buses del chorro Público)',
            'telefonos' => $company->number_phone ?? '2420-4997 y 6303-3392',
            'horario' => 'Lunes a Sábado de: 7:00 a.m. - 3:00 p.m.',
        ];

        try {
            $phpWord = new \PhpOffice\PhpWord\PhpWord();
            $phpWord->setDefaultFontName('Arial');
            $phpWord->setDefaultFontSize(10);

            $section = $phpWord->addSection([
                'marginTop' => 1440,
                'marginBottom' => 1440,
                'marginLeft' => 1440,
                'marginRight' => 1440,
            ]);

            // Línea superior
            $section->addText('_______________________________________________________________________________', [], ['alignment' => 'center']);

            // Encabezado con tres columnas usando tabla
            $headerTable = $section->addTable([
                'borderSize' => 0,
                'cellMargin' => 50,
            ]);
            $headerTable->addRow();

            // Columna izquierda: LABORATORIO - CLINICO - PRO-MEDIC
            $leftCell = $headerTable->addCell(3000);
            $leftCell->addText('LABORATORIO', ['bold' => true, 'size' => 14]);
            $leftCell->addText('- CLINICO -', ['bold' => true, 'size' => 12]);
            $leftCell->addText('PRO-MEDIC', ['bold' => true, 'size' => 14]);

            // Columna centro: Lema y dirección
            $centerCell = $headerTable->addCell(4000);
            $centerCell->addText('Calidad, Rapidez y Veracidad en sus resultados', ['size' => 10], ['alignment' => 'center']);
            $centerCell->addText('es lo que nos caracteriza.', ['size' => 10], ['alignment' => 'center']);
            $centerCell->addText('Dirección: Final Avenida El Calvario, Calle principal', ['bold' => true, 'size' => 10], ['alignment' => 'center']);
            $centerCell->addText('Nahuizalco (Frente a parada de buses del chorro Público)', ['bold' => true, 'size' => 10], ['alignment' => 'center']);

            // Columna derecha: HORARIO
            $rightCell = $headerTable->addCell(3000);
            $rightCell->addText('HORARIO', ['bold' => true, 'size' => 12], ['alignment' => 'right']);
            $rightCell->addText('Lunes a Sábado de:', ['size' => 10], ['alignment' => 'right']);
            $rightCell->addText('7:00 a.m. - 3:00 p.m.', ['bold' => true, 'size' => 10], ['alignment' => 'right']);

            // Línea separadora
            $section->addTextBreak(1);
            $section->addText('_______________________________________________________________________________', [], ['alignment' => 'center']);

            // Cuadro de información del paciente
            $section->addTextBreak(1);
            $patientName = $orderExam->order->patient
                ? ($orderExam->order->patient->primer_nombre . ' ' . $orderExam->order->patient->primer_apellido)
                : '';
            $patientAge = $orderExam->order->patient && $orderExam->order->patient->fecha_nacimiento
                ? \Carbon\Carbon::parse($orderExam->order->patient->fecha_nacimiento)->age
                : '';
            $doctorName = $orderExam->order->doctor
                ? ($orderExam->order->doctor->nombres . ' ' . $orderExam->order->doctor->apellidos)
                : '';
            $orderDate = $orderExam->order->fecha_orden
                ? \Carbon\Carbon::parse($orderExam->order->fecha_orden)->format('d/m/Y')
                : date('d/m/Y');

            // Tabla con bordes para paciente
            $patientTable = $section->addTable([
                'borderSize' => 6,
                'borderColor' => '000000',
                'cellMargin' => 80,
            ]);
            $patientTable->addRow();
            $patientTable->addCell(3000)->addText('Paciente: ' . $patientName, ['size' => 11]);
            $patientTable->addCell(3000)->addText('Edad: ' . $patientAge, ['size' => 11]);
            $patientTable->addRow();
            $patientTable->addCell(3000)->addText('Medico: ' . $doctorName, ['size' => 11]);
            $patientTable->addCell(3000)->addText('Fecha: ' . $orderDate, ['size' => 11]);

            $section->addTextBreak(1);

            // Tabla de resultados
            $table = $section->addTable([
                'borderSize' => 6,
                'borderColor' => '000000',
                'cellMargin' => 80,
            ]);

            // Encabezados de tabla
            $table->addRow();
            $table->addCell(4000)->addText('EXAMEN', ['bold' => true], ['alignment' => 'center']);
            $table->addCell(3000)->addText('RESULTADO', ['bold' => true], ['alignment' => 'center']);
            $table->addCell(3000)->addText('RANGO DE REFERENCIA', ['bold' => true], ['alignment' => 'center']);

            // Agregar resultados según el tipo de examen
            $examName = strtolower($orderExam->exam->nombre ?? '');
            $valoresRef = $orderExam->exam->valores_referencia_especificos ?? [];

            $isAcidoValproico = $orderExam->exam->template_id === 'acido_valproico'
                || str_contains($examName, 'ácido valpróico')
                || str_contains($examName, 'acido valproico');
            $isAlbumina = $orderExam->exam->template_id === 'albumina'
                || str_contains($examName, 'albúmina')
                || str_contains($examName, 'albumina');

            if ($isAcidoValproico) {
                // Categoría
                $table->addRow();
                $table->addCell(4000)->addText($valoresRef['categoria'] ?? 'DROGAS TERAPEUTICAS', ['bold' => true]);
                $table->addCell(3000)->addText('');
                $table->addCell(3000)->addText('');

                // Resultado
                $result = $orderExam->results->first();
                $resultValue = $result ? $result->resultado : '';
                $unit = $valoresRef['unidad_medida'] ?? ($result && $result->unidad_medida ? $result->unidad_medida : 'ug/mL');
                $resultText = $resultValue . ' ' . $unit;

                $refText = '';
                if (isset($valoresRef['terapeutico'])) {
                    $refText = 'Terapéutico: ' . ($valoresRef['terapeutico']['rango'] ?? '50 a 100 ug/mL');
                } else {
                    $refText = 'Terapéutico: 50 a 100 ug/mL';
                }
                if (isset($valoresRef['toxico'])) {
                    $refText .= "\nTóxico: " . ($valoresRef['toxico']['rango'] ?? 'Mayor de 100 ug/mL');
                } else {
                    $refText .= "\nTóxico: Mayor de 100 ug/mL";
                }

                $table->addRow();
                $table->addCell(4000)->addText($orderExam->exam->nombre . ':');
                $table->addCell(3000)->addText($resultText, [], ['alignment' => 'center']);
                $table->addCell(3000)->addText($refText);
            } elseif ($isAlbumina) {
                // Categoría
                $table->addRow();
                $table->addCell(4000)->addText($valoresRef['categoria'] ?? 'PRUEBAS RENALES', ['bold' => true]);
                $table->addCell(3000)->addText('');
                $table->addCell(3000)->addText('');

                // Resultado
                $result = $orderExam->results->first();
                $resultValue = $result ? $result->resultado : '';
                $unit = $valoresRef['unidad_medida'] ?? ($result && $result->unidad_medida ? $result->unidad_medida : 'g/dL');
                $resultText = $resultValue . ' ' . $unit;

                // Construir texto de referencia con todos los rangos
                $refText = '';
                if (isset($valoresRef['adultos'])) {
                    $refText = ($valoresRef['adultos']['label'] ?? 'Adultos') . ': ' . ($valoresRef['adultos']['rango'] ?? '3.5 a 5.2 g/dL');
                } else {
                    $refText = 'Adultos: 3.5 a 5.2 g/dL';
                }
                if (isset($valoresRef['neonatos_0_4_dias'])) {
                    $refText .= "\n" . ($valoresRef['neonatos_0_4_dias']['label'] ?? 'Neonatos 0 a 4 días') . ': ' . ($valoresRef['neonatos_0_4_dias']['rango'] ?? '2.8 a 4.4 g/dL');
                } else {
                    $refText .= "\nNeonatos 0 a 4 días: 2.8 a 4.4 g/dL";
                }
                if (isset($valoresRef['ninos_4_dias_14_anos'])) {
                    $refText .= "\n" . ($valoresRef['ninos_4_dias_14_anos']['label'] ?? 'Niños 4 días a 14 años') . ': ' . ($valoresRef['ninos_4_dias_14_anos']['rango'] ?? '3.8 a 5.4 g/dL');
                } else {
                    $refText .= "\nNiños 4 días a 14 años: 3.8 a 5.4 g/dL";
                }
                if (isset($valoresRef['ninos_14_18_anos'])) {
                    $refText .= "\n" . ($valoresRef['ninos_14_18_anos']['label'] ?? 'Niños 14 años a 18 años') . ': ' . ($valoresRef['ninos_14_18_anos']['rango'] ?? '3.2 a 4.5 g/dL');
                } else {
                    $refText .= "\nNiños 14 años a 18 años: 3.2 a 4.5 g/dL";
                }

                $table->addRow();
                $table->addCell(4000)->addText($orderExam->exam->nombre . ':');
                $table->addCell(3000)->addText($resultText, [], ['alignment' => 'center']);
                $table->addCell(3000)->addText($refText);
            } else {
                $this->addExamResultsToTable($table, $examName, $orderExam->results);
            }

            // Espacios en blanco
            $section->addTextBreak(7);

            // Validación (centrado) - mostrar el médico que autorizó/ordenó la prueba
            $doctorNameFooter = $orderExam->order->doctor
                ? ($orderExam->order->doctor->nombres . ' ' . $orderExam->order->doctor->apellidos)
                : '';

            $validationText = 'Validado por:';
            if ($doctorNameFooter) {
                $validationText .= ' ' . $doctorNameFooter;
            }

            $section->addText($validationText, ['size' => 11], ['alignment' => 'center']);

            // Línea separadora final
            $section->addTextBreak(1);
            $section->addText('________________________________________________________________________________________', [], ['alignment' => 'center']);

            // Pie de página
            $section->addText(
                'LABORATORIO CLINICO PRO-MEDIC      -      Teléfonos: ' . $labInfo['telefonos'],
                ['size' => 10],
                ['alignment' => 'center']
            );

            // Guardar el documento
            $fileName = 'resultado_' . str_replace(' ', '_', $orderExam->exam->nombre) . '_' . date('Y-m-d') . '.docx';
            $tempFile = tempnam(sys_get_temp_dir(), 'lab_result_');
            $objWriter = \PhpOffice\PhpWord\IOFactory::createWriter($phpWord, 'Word2007');
            $objWriter->save($tempFile);

            return response()->download($tempFile, $fileName)->deleteFileAfterSend(true);

        } catch (\Exception $e) {
            \Log::error('Error generando DOC de resultado: ' . $e->getMessage());
            return back()->with('error', 'Error al generar el documento: ' . $e->getMessage());
        }
    }

