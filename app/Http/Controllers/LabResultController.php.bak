                'salmonella_paratyphi_ah' => 'SALMONELLA PARATYPHI AH',
                'salmonella_paratyphi_bh' => 'SALMONELLA PARATYPHI BH',
                'salmonella_typhi_h' => 'SALMONELLA TYPHI H',
                'salmonella_typhi_o' => 'SALMONELLA TYPHI O',
                'brucella_abortus' => 'BRUCELLA ABORTUS',
                'proteus_ox19' => 'PROTEUS OX19'
            ];

            $resultsCreated = [];
            foreach ($parametros as $key => $nombreParametro) {
                $campoResultado = 'resultado_' . $key;
                $resultadoValue = strtoupper(trim($validated[$campoResultado]));

                // Normalizar resultado
                if (stripos($resultadoValue, 'NEGATIVO') !== false) {
                    $resultadoDisplay = 'NEGATIVO';
                } elseif (stripos($resultadoValue, 'POSITIVO') !== false) {
                    // Si tiene título (1:20, 1:40, etc.), mantenerlo
                    if (preg_match('/POSITIVO\s*(\d+:\d+)/i', $resultadoValue, $matches)) {
                        $resultadoDisplay = 'POSITIVO ' . $matches[1];
                    } else {
                        $resultadoDisplay = 'POSITIVO';
                    }
                } else {
                    $resultadoDisplay = $resultadoValue;
                }

                $valorRefText = $valoresRef[$key]['rango'] ?? 'Negativo';

                $labResult = LabResult::create([
                    'order_exam_id' => $orderExamId,
                    'parametro' => $nombreParametro,
                    'resultado' => $resultadoDisplay,
