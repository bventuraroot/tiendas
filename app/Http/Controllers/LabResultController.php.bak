                    'fecha_procesamiento' => now(),
                    'procesado_por' => Auth::id(),
                ]);

                $resultsCreated[$key] = $labResult->load('processedBy');
            }

            // Actualizar estado del examen de la orden
            $orderExam->update(['estado' => 'completado']);

            return response()->json([
