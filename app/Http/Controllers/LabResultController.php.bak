                $valoresRef = $valoresRef['valores_referencia'] ?? $valoresRef;
            }

            $unidad = $exam->valores_referencia_especificos['unidad_medida'] ?? config('lab_exam_templates.ca15_3.unidad_medida', 'U/mL');
            $resultado = (float)$validated['resultado'];
            $estado = $validated['estado_resultado'];
            $critico = ($estado === 'critico');

            // Construir valor de referencia
            $valorRefText = $valoresRef['normal']['rango'] ?? 'Hasta 25 U/mL';

            $result->update([
                'resultado' => $resultado,
                'unidad_medida' => $unidad,
                'valor_referencia' => $valorRefText,
                'estado_resultado' => $estado,
                'resultado_critico' => $critico,
                'observaciones' => !empty($validated['observaciones']) ? $validated['observaciones'] : '**DATOS CONTROLADOS**',
            ]);

            return response()->json([
                'success' => true,
                'message' => 'Resultado actualizado exitosamente',
                'result' => $result->load('processedBy')
            ]);
        } else {
            // CASO GENÉRICO: Usar datos del catálogo de exámenes para todos los exámenes
            $validated = $request->validate([
                'resultado' => 'required',
                'valor_referencia' => 'required|string',
                'unidad_medida' => 'nullable|string|max:50',
                'estado_resultado' => 'required|in:normal,alto,bajo,critico',
                'observaciones' => 'nullable|string',
            ]);

            // Obtener unidad de medida: primero del formulario, luego del catálogo
            $unidadMedida = $validated['unidad_medida'] 
                ?? $exam->unidad_medida 
                ?? $exam->valores_referencia_especificos['unidad_medida'] 
                ?? $result->unidad_medida; // Mantener la existente si no hay en BD

            // Obtener valor de referencia: primero del formulario (puede ser editado), luego del catálogo como default
            $valorReferencia = !empty($validated['valor_referencia']) 
                ? $validated['valor_referencia'] 
                : ($exam->valores_referencia 
                    ?? $exam->valores_referencia_especificos['valores_referencia']['rango'] 
                    ?? $exam->valores_referencia_especificos['rango'] 
                    ?? $result->valor_referencia); // Mantener el existente si no hay en BD

            // Usar el nombre del examen como parámetro automáticamente
            $result->update([
                'parametro' => $exam->nombre, // Mantener el nombre del examen como parámetro
                'resultado' => is_numeric($validated['resultado']) ? (float)$validated['resultado'] : $validated['resultado'],
                'unidad_medida' => $unidadMedida,
                'valor_referencia' => $valorReferencia,
                'estado_resultado' => $validated['estado_resultado'],
                'resultado_critico' => $validated['estado_resultado'] === 'critico',
                'observaciones' => !empty($validated['observaciones']) ? $validated['observaciones'] : '**DATOS CONTROLADOS**',
            ]);

            return response()->json([
                'success' => true,
                'message' => 'Resultado actualizado exitosamente',
                'result' => $result->load('processedBy')
            ]);
        }
    }

    /**
     * Validar un resultado
     */
    public function validateResult(Request $request, $resultId)
    {
        $result = LabResult::findOrFail($resultId);

        $result->update([
            'validado_por' => Auth::id(),
            'fecha_validacion' => now(),
        ]);

        return response()->json([
            'success' => true,
            'message' => 'Resultado validado exitosamente'
        ]);
    }

    /**
     * Agregar resultados a la tabla según el tipo de examen
     */
    private function addExamResultsToTable($table, $examName, $results)
    {
        if (str_contains($examName, 'ácido valpróico') || str_contains($examName, 'acido valproico') || str_contains($examName, 'valpróico') || str_contains($examName, 'valproico')) {
            // Formato específico para Ácido Valpróico
            $table->addRow();
            $table->addCell(5000)->addText('DROGAS TERAPEUTICAS');
            $table->addCell(3000)->addText('');
            $table->addCell(4000)->addText('');

            $table->addRow();
            $resultValue = $results->first() ? $results->first()->resultado : '';
            $unit = $results->first() && $results->first()->unidad_medida ? $results->first()->unidad_medida : 'ug/mL';
            $table->addCell(5000)->addText('Ácido Valpróico:');
            $table->addCell(3000)->addText($resultValue . ' ' . $unit);
            $table->addCell(4000)->addText("Terapéutico: 50 a 100 ug/mL\nTóxico: Mayor de 100 ug/mL");
        } else {
            // Formato genérico
            foreach ($results as $result) {
                $table->addRow();
                $table->addCell(5000)->addText($result->parametro);
                $resultText = $result->resultado;
                if ($result->unidad_medida) {
                    $resultText .= ' ' . $result->unidad_medida;
                }
                $table->addCell(3000)->addText($resultText);
                $table->addCell(4000)->addText($result->valor_referencia ?? 'N/A');
            }
        }
    }
}

