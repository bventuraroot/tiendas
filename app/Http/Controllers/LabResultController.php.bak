            // Normalizar resultado
            $resultadoNormalizado = strtolower($validated['resultado']);
            if (str_contains($resultadoNormalizado, 'no reactivo') || str_contains($resultadoNormalizado, 'no_reactivo')) {
                $resultadoDisplay = 'NO REACTIVO A LA FECHA';
            } elseif (str_contains($resultadoNormalizado, 'reactivo')) {
                $resultadoDisplay = 'REACTIVO';
