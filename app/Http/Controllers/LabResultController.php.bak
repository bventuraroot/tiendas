            if (!empty($validated['marca_reactivo'])) {
                $camposAdicionales['marca_reactivo'] = $validated['marca_reactivo'];
            }
            if (!empty($validated['metodo_prueba'])) {
                $camposAdicionales['metodo_prueba'] = $validated['metodo_prueba'];
            }

            // Guardar observaciones normales y campos adicionales en JSON
            $observacionesTexto = !empty($validated['observaciones']) ? $validated['observaciones'] : '**DATOS CONTROLADOS**';
