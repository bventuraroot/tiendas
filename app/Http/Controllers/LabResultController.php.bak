                'Glucosa en Ayunas' => 'resultado_ayunas',
                'Glucosa 1 Hora después de la toma' => 'resultado_1h',
                'Glucosa 2 Horas después de la toma' => 'resultado_2h',
                'Glucosa 3 Horas después de la toma' => 'resultado_3h',
            ];

            foreach ($map as $parametro => $field) {
                $existingResult = LabResult::where('order_exam_id', $orderExam->id)
                    ->where('parametro', $parametro)
                    ->first();

                if ($existingResult) {
