    /**
     * Mostrar formulario para agregar resultados
     */
    public function create($orderExamId)
    {
        $orderExam = LabOrderExam::with([
            'order.patient',
            'order.doctor',
            'exam',
            'results' // Cargar resultados existentes para poder editarlos
        ])->findOrFail($orderExamId);

        return view('laboratory.results.create', compact('orderExam'));
    }

    /**
     * Guardar resultados de un examen
     */
    public function store(Request $request, $orderExamId)
    {
        $orderExam = LabOrderExam::with('exam')->findOrFail($orderExamId);
        $exam = $orderExam->exam;

        // Validar según el tipo de examen
        $examName = strtolower($exam->nombre ?? '');
        $isAcidoValproico = $exam->template_id === 'acido_valproico'
            || str_contains($examName, 'ácido valpróico')
            || str_contains($examName, 'acido valproico')
            || str_contains($examName, 'valpróico')
            || str_contains($examName, 'valproico');

        $isAlbumina = $exam->template_id === 'albumina'
            || str_contains($examName, 'albúmina')
            || str_contains($examName, 'albumina');

        $isAmilasaLipasa = $exam->template_id === 'amilasa_lipasa'
            || (str_contains($examName, 'amilasa') && str_contains($examName, 'lipasa'));

        $isAnaTamizaje = $exam->template_id === 'ana_tamizaje'
            || str_contains($examName, 'antinucleares')
            || str_contains($examName, 'ana tamizaje')
            || (str_contains($examName, 'ana') && str_contains($examName, 'tamizaje'));

        $isAntigenosFebriles = $exam->template_id === 'antigenos_febriles'
            || str_contains($examName, 'antigenos febriles')
            || str_contains($examName, 'antígenos febriles')
            || str_contains($examName, 'antigeno febril');

        $isAntimicrosomales = $exam->template_id === 'antimicrosomales'
            || str_contains($examName, 'antimicrosomales')
            || str_contains($examName, 'anti tpo')
            || str_contains($examName, 'atm');
        $isCoprocultivo = $exam->template_id === 'coprocultivo'
            || str_contains($examName, 'coprocultivo');

        $isGeneralOrina = $exam->template_id === 'general_orina'
            || str_contains($examName, 'general de orina')
            || str_contains($examName, 'orina completa');

        $isFrotisSangrePeriferica = $exam->template_id === 'frotis_sangre_periferica'
            || str_contains($examName, 'frotis de sangre periferica')
            || str_contains($examName, 'frotis sangre periférica')
            || str_contains($examName, 'frotis periferica');

        $isGlucosa = $exam->template_id === 'glucosa'
            || (str_contains($examName, 'glucosa') && str_contains($examName, 'ayunas'))
            || (str_contains($examName, 'glucosa') && str_contains($examName, 'post-prandial'))
            || (str_contains($examName, 'glucosa') && str_contains($examName, 'post prandial'));

        $isProlactina = $exam->template_id === 'prolactina'
            || str_contains($examName, 'prolactina')
            || str_contains($examName, 'prl')
            || str_contains($examName, 'prolactin');

        $isBhcgCualitativa = $exam->template_id === 'bhcg_cualitativa'
            || str_contains($examName, 'bhcg cualitativa')
            || str_contains($examName, 'b-hcg cualitativa')
            || str_contains($examName, 'beta hcg cualitativa')
            || (str_contains($examName, 'hcg') && str_contains($examName, 'cualitativa'));

        $isPerfilBioquimicaClinica = $exam->template_id === 'perfil_bioquimica_clinica'
            || str_contains($examName, 'perfil bioquimica clinica')
            || str_contains($examName, 'perfil bioquímica clínica')
            || (str_contains($examName, 'bioquimica') && str_contains($examName, 'clinica'));

        $isProteinaCReactiva = $exam->template_id === 'proteina_c_reactiva'
            || str_contains($examName, 'proteína c reactiva')
            || str_contains($examName, 'proteina c reactiva')
            || str_contains($examName, 'pcr')
            || (str_contains($examName, 'c reactive') && str_contains($examName, 'protein'));

        $isPruebaAzulMetileno = $exam->template_id === 'prueba_azul_metileno'
            || str_contains($examName, 'prueba de azul de metileno')
            || str_contains($examName, 'azul de metileno')
            || str_contains($examName, 'p.a.m.')
            || str_contains($examName, 'pam');

        $isInsulina = $exam->template_id === 'insulina'
            || str_contains($examName, 'insulina')
            || str_contains($examName, 'insulin');

        $isHormonaLuteinizante = $exam->template_id === 'hormona_luteinizante'
            || str_contains($examName, 'hormona luteinizante')
            || str_contains($examName, 'lh')
            || (str_contains($examName, 'luteinizing') && str_contains($examName, 'hormone'));

        $isHormonaFolículoEstimulante = $exam->template_id === 'hormona_folículo_estimulante'
            || str_contains($examName, 'hormona folículo estimulante')
            || str_contains($examName, 'hormona folículo')
            || str_contains($examName, 'fsh')
            || (str_contains($examName, 'follicle stimulating') && str_contains($examName, 'hormone'));

        $isHormonaCrecimiento = $exam->template_id === 'hormona_crecimiento'
            || str_contains($examName, 'hormona del crecimiento')
            || str_contains($examName, 'hormona crecimiento')
            || str_contains($examName, 'hgh')
            || (str_contains($examName, 'growth hormone') && str_contains($examName, 'pre-ejercicio'));

        $isHepatitisAIgm = $exam->template_id === 'hepatitis_a_igm'
            || (str_contains($examName, 'hepatitis a') && (str_contains($examName, 'igm') || str_contains($examName, 'ig m')));

        $isHemograma = $exam->template_id === 'hemograma'
            || str_contains($examName, 'hemograma')
            || str_contains($examName, 'hematologia completa')
            || str_contains($examName, 'hematología completa');

        $isHematocritoHemoglobina = $exam->template_id === 'hematocrito_hemoglobina'
            || (str_contains($examName, 'hematocrito') && str_contains($examName, 'hemoglobina'))
            || str_contains($examName, 'hematocrito y hemoglobina');

        $isHemoglobinaGlicosilada = $exam->template_id === 'hemoglobina_glicosilada'
            || str_contains($examName, 'hemoglobina glicosilada')
            || str_contains($examName, 'hemoglobina glicosilada a1c')
            || str_contains($examName, 'hba1c')
            || str_contains($examName, 'hb a1c');

        $isAntigenosHelicobacterPylori = $exam->template_id === 'antigenos_helicobacter_pylori'
            || ((str_contains($examName, 'antigenos helicobacter') || str_contains($examName, 'antígenos helicobacter')) && (str_contains($examName, 'heces') || str_contains($examName, 'coprologia') || str_contains($examName, 'coprología')));

        $isHelicobacterPylori = $exam->template_id === 'helicobacter_pylori'
            || str_contains($examName, 'helicobacter pylori')
            || str_contains($examName, 'helicobacter')
            || (str_contains($examName, 'anti-helicobacter') && str_contains($examName, 'igg'))
            || (str_contains($examName, 'anti-helicobacter') && str_contains($examName, 'igm'));

        $isToxoplasmaGondii = $exam->template_id === 'toxoplasma_gondii'
            || str_contains($examName, 'toxoplasma gondii')
            || str_contains($examName, 'toxoplasma')
            || (str_contains($examName, 'toxoplasma') && (str_contains($examName, 'igg') || str_contains($examName, 'igm')));

        $isCurvaGlucosa = $exam->template_id === 'curva_tolerancia_glucosa'
            || str_contains($examName, 'curva de la tolerancia a la glucosa')
