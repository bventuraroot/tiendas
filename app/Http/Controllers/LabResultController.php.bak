                $camposAdicionales['susceptible'] = $validated['susceptible'];
            }
            if (!empty($validated['intermedio'])) {
                $camposAdicionales['intermedio'] = $validated['intermedio'];
            }
            if (!empty($validated['resistente'])) {
                $camposAdicionales['resistente'] = $validated['resistente'];
