                'resultado_critico' => $validated['estado_resultado_igm'] === 'critico',
                'observaciones' => !empty($validated['observaciones']) ? $validated['observaciones'] : '**DATOS CONTROLADOS**',
                'fecha_procesamiento' => now(),
