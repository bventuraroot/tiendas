            $observacionesCompletas = $observacionesTexto;
            if (!empty($camposAdicionales)) {
                $observacionesCompletas .= ($observacionesCompletas ? "\n\n" : '') . '__CAMPOS_ADICIONALES__' . json_encode($camposAdicionales, JSON_UNESCAPED_UNICODE);
            }

            // Crear resultado para UROCULTIVO
            $labResult = LabResult::create([
                'order_exam_id' => $orderExamId,
                'parametro' => 'UROCULTIVO (Cultivo de Orina)',
                'resultado' => (float)$validated['recuento_bacteriano'],
                'unidad_medida' => 'UFC/mL',
                'valor_referencia' => '',
                'estado_resultado' => $validated['estado_resultado'],
                'resultado_critico' => $validated['estado_resultado'] === 'critico',
                'observaciones' => !empty($observacionesCompletas) ? $observacionesCompletas : '**DATOS CONTROLADOS**',
                'fecha_procesamiento' => now(),
                'procesado_por' => Auth::id(),
            ]);

            // Actualizar estado del examen de la orden
            $orderExam->update(['estado' => 'completado']);

            return response()->json([
                'success' => true,
                'message' => 'Resultado registrado exitosamente',
                'result' => $labResult->load('processedBy')
            ]);
        } else {
            // CASO GENÉRICO: Usar datos del catálogo de exámenes para todos los exámenes
            // Validar campos básicos
            $validated = $request->validate([
                'resultado' => 'required',
                'valor_referencia' => 'required|string',
                'unidad_medida' => 'nullable|string|max:50',
                'estado_resultado' => 'required|in:normal,alto,bajo,critico',
                'observaciones' => 'nullable|string',
            ]);

            // Obtener unidad de medida: primero del formulario, luego del catálogo
            $unidadMedida = $validated['unidad_medida'] 
                ?? $exam->unidad_medida 
                ?? $exam->valores_referencia_especificos['unidad_medida'] ?? null;

            // Obtener valor de referencia: primero del formulario (puede ser editado), luego del catálogo como default
            $valorReferencia = !empty($validated['valor_referencia']) 
                ? $validated['valor_referencia'] 
                : ($exam->valores_referencia 
                    ?? $exam->valores_referencia_especificos['valores_referencia']['rango'] 
                    ?? $exam->valores_referencia_especificos['rango'] 
                    ?? '');

            // Usar el nombre del examen como parámetro automáticamente
            $labResult = LabResult::create([
                'order_exam_id' => $orderExamId,
                'parametro' => $exam->nombre,
                'resultado' => is_numeric($validated['resultado']) ? (float)$validated['resultado'] : $validated['resultado'],
                'unidad_medida' => $unidadMedida,
                'valor_referencia' => $valorReferencia,
                'estado_resultado' => $validated['estado_resultado'],
                'resultado_critico' => $validated['estado_resultado'] === 'critico',
                'observaciones' => !empty($validated['observaciones']) ? $validated['observaciones'] : '**DATOS CONTROLADOS**',
                'fecha_procesamiento' => now(),
                'procesado_por' => Auth::id(),
            ]);

            // Actualizar estado del examen de la orden
            $orderExam->update(['estado' => 'completado']);

            return response()->json([
                'success' => true,
                'message' => 'Resultado registrado exitosamente',
                'result' => $labResult->load('processedBy')
            ]);
        }
    }

    /**
     * Mostrar formulario para editar un resultado
     */
    public function edit($resultId)
    {
        $result = LabResult::with([
            'orderExam.order.patient',
            'orderExam.order.doctor',
            'orderExam.exam'
        ])->findOrFail($resultId);

        $orderExam = $result->orderExam;
        $exam = $orderExam->exam;

        // Verificar que la orden no esté autorizada
        if (in_array($orderExam->order->estado, ['completada', 'entregada'])) {
            return redirect()->route('lab-orders.show', $orderExam->order_id)
                ->with('error', 'No se puede editar el resultado porque la orden ya está autorizada.');
        }

        // Solo definir variables para exámenes que realmente necesitan manejo especial (múltiples parámetros o campos especiales)
        $examName = strtolower($exam->nombre ?? '');
        
        // Exámenes con múltiples parámetros o campos especiales
        $isBilirrubina = $exam->template_id === 'bilirrubina' || str_contains($examName, 'bilirrubina');
        $isHdlLdl = $exam->template_id === 'hdl_ldl' || str_contains($examName, 'hdl y ldl') || (str_contains($examName, 'hdl') && str_contains($examName, 'ldl'));
        $isCoombs = $exam->template_id === 'coombs' || str_contains($examName, 'coombs');
        $isCoprocultivo = $exam->template_id === 'coprocultivo' || str_contains($examName, 'coprocultivo');
        $isFrotisSangrePeriferica = $exam->template_id === 'frotis_sangre_periferica' || str_contains($examName, 'frotis');
        $isGeneralOrina = $exam->template_id === 'general_orina' || str_contains($examName, 'general de orina') || str_contains($examName, 'orina completa');
        $isUrocultivo = $exam->template_id === 'urocultivo' || str_contains($examName, 'urocultivo');
        $isGlucosa = $exam->template_id === 'glucosa' || (str_contains($examName, 'glucosa') && (str_contains($examName, 'ayunas') || str_contains($examName, 'post-prandial')));
        $isAnticuerposTotalesHelicobacterPylori = $exam->template_id === 'anticuerpos_totales_helicobacter_pylori' || (str_contains($examName, 'anticuerpos totales helicobacter') && !str_contains($examName, 'igg') && !str_contains($examName, 'igm'));
        $isAntigenosHelicobacterPylori = $exam->template_id === 'antigenos_helicobacter_pylori' || (str_contains($examName, 'antigenos helicobacter') && (str_contains($examName, 'heces') || str_contains($examName, 'coprologia')));
        $isHelicobacterPylori = $exam->template_id === 'helicobacter_pylori' || (str_contains($examName, 'helicobacter') && (str_contains($examName, 'igg') || str_contains($examName, 'igm')));
        $isToxoplasmaGondii = $exam->template_id === 'toxoplasma_gondii' || (str_contains($examName, 'toxoplasma') && (str_contains($examName, 'igg') || str_contains($examName, 'igm')));
        $isCurvaGlucosa = $exam->template_id === 'curva_tolerancia_glucosa' || str_contains($examName, 'curva tolerancia glucosa');
        $isTptTp = $exam->template_id === 'tpt_tp' || str_contains($examName, 'tpt y tp') || str_contains($examName, 'tpt tp');
        $isTiroideasT3T4Tsh = $exam->template_id === 'tiroideas_t3_t4_tsh' || (str_contains($examName, 'tiroideas') && str_contains($examName, 't3') && str_contains($examName, 't4') && str_contains($examName, 'tsh'));
        $isPruebasTiroideas = $exam->template_id === 'pruebas_tiroideas' || str_contains($examName, 'pruebas tiroideas');
        $isVih = $exam->template_id === 'vih' || str_contains($examName, 'vih') || str_contains($examName, 'virus inmunodeficiencia');
        $isVdrlRpr = $exam->template_id === 'vdrl_rpr' || (str_contains($examName, 'vdrl') && str_contains($examName, 'rpr'));
        $isVdrlCardiolipina = $exam->template_id === 'vdrl_cardiolipina' || (str_contains($examName, 'vdrl') && str_contains($examName, 'cardiolipina'));
        $isPerfilBioquimicaClinica = $exam->template_id === 'perfil_bioquimica_clinica' || str_contains($examName, 'perfil bioquimica clinica');
        $isHemograma = $exam->template_id === 'hemograma' || str_contains($examName, 'hemograma') || str_contains($examName, 'hematologia completa');
        $isHematocritoHemoglobina = $exam->template_id === 'hematocrito_hemoglobina' || (str_contains($examName, 'hematocrito') && str_contains($examName, 'hemoglobina'));
        $isTestOsullivan = $exam->template_id === 'test_osullivan' || str_contains($examName, 'osullivan');
        $isAntigenosFebriles = $exam->template_id === 'antigenos_febriles' || str_contains($examName, 'antigenos febriles');
        $isAcidoValproico = $exam->template_id === 'acido_valproico' || str_contains($examName, 'acido valproico');
        $isAmilasaLipasa = $exam->template_id === 'amilasa_lipasa' || (str_contains($examName, 'amilasa') && str_contains($examName, 'lipasa'));
        $isDepuracionCreatinina = $exam->template_id === 'depuracion_creatinina' || str_contains($examName, 'depuracion creatinina');
        $isPruebaAzulMetileno = $exam->template_id === 'prueba_azul_metileno' || str_contains($examName, 'prueba de azul de metileno') || str_contains($examName, 'azul de metileno') || str_contains($examName, 'p.a.m.') || str_contains($examName, 'pam');

        if ($isUrocultivo) {
            // Extraer campos adicionales del JSON en observaciones
            $resultadoCombinado = (object)[
                'recuento_bacteriano' => $result->resultado ?? '',
                'estado_resultado' => $result->estado_resultado ?? '',
                'susceptible' => '',
                'intermedio' => '',
                'resistente' => '',
                'observaciones' => '',
            ];

            if ($result->observaciones) {
                $observaciones = $result->observaciones;
                if (str_contains($observaciones, '__CAMPOS_ADICIONALES__')) {
                    $parts = explode('__CAMPOS_ADICIONALES__', $observaciones);
                    $resultadoCombinado->observaciones = trim($parts[0]);
                    if (count($parts) > 1) {
                        $jsonData = json_decode($parts[1], true);
                        if ($jsonData) {
                            $resultadoCombinado->susceptible = $jsonData['susceptible'] ?? '';
                            $resultadoCombinado->intermedio = $jsonData['intermedio'] ?? '';
                            $resultadoCombinado->resistente = $jsonData['resistente'] ?? '';
                        }
                    }
                } else {
                    $resultadoCombinado->observaciones = $observaciones;
                }
            }

            $result = $resultadoCombinado;
            return view('laboratory.results.create', compact('orderExam', 'result'));
        }

        if ($isCoprocultivo) {
            // Extraer campos adicionales del JSON en observaciones
            $resultadoCombinado = (object)[
                'resultado' => $result->resultado ?? '',
                'estado_resultado' => $result->estado_resultado ?? '',
                'susceptible' => '',
                'intermedio' => '',
                'resistente' => '',
                'tipo_muestra' => '',
                'observaciones' => '',
            ];

            if ($result->observaciones) {
                $observaciones = $result->observaciones;
                if (str_contains($observaciones, '__CAMPOS_ADICIONALES__')) {
                    $parts = explode('__CAMPOS_ADICIONALES__', $observaciones);
                    $resultadoCombinado->observaciones = trim($parts[0]);
                    if (count($parts) > 1) {
                        $jsonData = json_decode($parts[1], true);
                        if ($jsonData) {
                            $resultadoCombinado->susceptible = $jsonData['susceptible'] ?? '';
                            $resultadoCombinado->intermedio = $jsonData['intermedio'] ?? '';
                            $resultadoCombinado->resistente = $jsonData['resistente'] ?? '';
                            $resultadoCombinado->tipo_muestra = $jsonData['tipo_muestra'] ?? '';
                        }
                    }
                } else {
                    $resultadoCombinado->observaciones = $observaciones;
                }
            }

            $result = $resultadoCombinado;
            return view('laboratory.results.create', compact('orderExam', 'result'));
        }

        if ($isToxoplasmaGondii) {
            // Toxoplasma gondii IgG/IgM - examen multi-parámetro
            $results = LabResult::where('order_exam_id', $orderExam->id)
                ->whereIn('parametro', ['Toxoplasma gondii IgG', 'Toxoplasma gondii IgM'])
                ->get();

            // Crear un objeto resultado combinado para la vista
            $combinedResult = (object)[
                'resultado_igg' => $results->firstWhere('parametro', 'Toxoplasma gondii IgG')->resultado ?? '',
                'estado_resultado_igg' => $results->firstWhere('parametro', 'Toxoplasma gondii IgG')->estado_resultado ?? '',
                'resultado_igm' => $results->firstWhere('parametro', 'Toxoplasma gondii IgM')->resultado ?? '',
                'estado_resultado_igm' => $results->firstWhere('parametro', 'Toxoplasma gondii IgM')->estado_resultado ?? '',
                'observaciones' => $results->first()->observaciones ?? null,
            ];

            $result = $combinedResult;
            return view('laboratory.results.create', compact('orderExam', 'result'));
        }

        // Tiroglobulina y otros exámenes simples usan el caso genérico al final

        if ($isGeneralOrina) {
            // Extraer campos adicionales del JSON en observaciones para General de Orina
            $resultadoCombinado = (object)[
                'resultado' => $result->resultado ?? '',
                'estado_resultado' => $result->estado_resultado ?? '',
                'color' => '',
                'aspecto' => '',
                'densidad' => '',
                'ph' => '',
                'urobilinogeno' => '',
                'bilirrubina' => '',
                'cuerpos_cetonicos' => '',
                'nitritos' => '',
                'sangre_hemoglobina' => '',
                'esterasa_leucocitaria' => '',
                'proteinas' => '',
                'glucosa' => '',
                'celulas_epiteliales' => '',
                'filamentos_mucoides' => '',
                'bacterias' => '',
                'leucocitos' => '',
                'eritrocitos' => '',
                'cilindros' => '',
                'cristales' => '',
                'levaduras' => '',
                'observaciones' => '',
            ];

            if ($result->observaciones) {
                $observaciones = $result->observaciones;
                if (str_contains($observaciones, '__CAMPOS_ADICIONALES__')) {
                    $parts = explode('__CAMPOS_ADICIONALES__', $observaciones);
                    $resultadoCombinado->observaciones = trim($parts[0]);
                    if (count($parts) > 1) {
                        $jsonData = json_decode($parts[1], true);
                        if ($jsonData) {
                            $resultadoCombinado->color = $jsonData['color'] ?? '';
                            $resultadoCombinado->aspecto = $jsonData['aspecto'] ?? '';
                            $resultadoCombinado->densidad = $jsonData['densidad'] ?? '';
                            $resultadoCombinado->ph = $jsonData['ph'] ?? '';
                            $resultadoCombinado->urobilinogeno = $jsonData['urobilinogeno'] ?? '';
                            $resultadoCombinado->bilirrubina = $jsonData['bilirrubina'] ?? '';
                            $resultadoCombinado->cuerpos_cetonicos = $jsonData['cuerpos_cetonicos'] ?? '';
                            $resultadoCombinado->nitritos = $jsonData['nitritos'] ?? '';
                            $resultadoCombinado->sangre_hemoglobina = $jsonData['sangre_hemoglobina'] ?? '';
                            $resultadoCombinado->esterasa_leucocitaria = $jsonData['esterasa_leucocitaria'] ?? '';
                            $resultadoCombinado->proteinas = $jsonData['proteinas'] ?? '';
                            $resultadoCombinado->glucosa = $jsonData['glucosa'] ?? '';
                            $resultadoCombinado->celulas_epiteliales = $jsonData['celulas_epiteliales'] ?? '';
                            $resultadoCombinado->filamentos_mucoides = $jsonData['filamentos_mucoides'] ?? '';
                            $resultadoCombinado->bacterias = $jsonData['bacterias'] ?? '';
                            $resultadoCombinado->leucocitos = $jsonData['leucocitos'] ?? '';
                            $resultadoCombinado->eritrocitos = $jsonData['eritrocitos'] ?? '';
                            $resultadoCombinado->cilindros = $jsonData['cilindros'] ?? '';
                            $resultadoCombinado->cristales = $jsonData['cristales'] ?? '';
                            $resultadoCombinado->levaduras = $jsonData['levaduras'] ?? '';
                        }
                    }
                } else {
                    $resultadoCombinado->observaciones = $observaciones;
                }
            }

            $result = $resultadoCombinado;
            return view('laboratory.results.create', compact('orderExam', 'result'));
        }

        if ($isTestOsullivan) {
            // Test de O'Sullivan - examen multi-parámetro (Glucosa en Ayunas, 1 Hora, 2 Horas)
            $resultAyunas = LabResult::where('order_exam_id', $orderExam->id)
                ->where('parametro', 'Glucosa en Ayunas')
                ->first();

            $result1Hora = LabResult::where('order_exam_id', $orderExam->id)
                ->where('parametro', 'Glucosa 1 Hora después de la toma')
                ->first();

            $result2Horas = LabResult::where('order_exam_id', $orderExam->id)
                ->where('parametro', 'Glucosa 2 Hora después de la toma')
                ->first();

            // Combinar resultados en un objeto
            $resultadoCombinado = (object)[
                'resultado_glucosa_ayunas' => $resultAyunas ? $resultAyunas->resultado : '',
                'estado_resultado_glucosa_ayunas' => $resultAyunas ? $resultAyunas->estado_resultado : '',
                'resultado_glucosa_1_hora' => $result1Hora ? $result1Hora->resultado : '',
                'estado_resultado_glucosa_1_hora' => $result1Hora ? $result1Hora->estado_resultado : '',
                'resultado_glucosa_2_horas' => $result2Horas ? $result2Horas->resultado : '',
                'estado_resultado_glucosa_2_horas' => $result2Horas ? $result2Horas->estado_resultado : '',
                'observaciones' => $resultAyunas ? $resultAyunas->observaciones : '',
            ];

            $result = $resultadoCombinado;
            return view('laboratory.results.create', compact('orderExam', 'result'));
        }

        if ($isCurvaGlucosa) {
            // Curva de la Tolerancia a la Glucosa - examen multi-parámetro (4 tiempos)
            $resultAyunas = LabResult::where('order_exam_id', $orderExam->id)
                ->where('parametro', 'Glucosa en Ayunas')
                ->first();

            $result1Hora = LabResult::where('order_exam_id', $orderExam->id)
                ->where('parametro', 'Glucosa 1 Hora después de la toma')
                ->first();

            $result2Horas = LabResult::where('order_exam_id', $orderExam->id)
                ->where('parametro', 'Glucosa 2 Horas después de la toma')
                ->first();

            $result3Horas = LabResult::where('order_exam_id', $orderExam->id)
                ->where('parametro', 'Glucosa 3 Horas después de la toma')
                ->first();

            // Combinar resultados en un objeto
            $resultadoCombinado = (object)[
                'resultado_ayunas' => $resultAyunas ? $resultAyunas->resultado : '',
                'resultado_1h' => $result1Hora ? $result1Hora->resultado : '',
                'resultado_2h' => $result2Horas ? $result2Horas->resultado : '',
                'resultado_3h' => $result3Horas ? $result3Horas->resultado : '',
                'estado_resultado' => $resultAyunas ? $resultAyunas->estado_resultado : '',
                'observaciones' => $resultAyunas ? $resultAyunas->observaciones : '',
            ];

            $result = $resultadoCombinado;
            return view('laboratory.results.create', compact('orderExam', 'result'));
        }

        if ($isTptTp) {
            // TPT Y TP - examen multi-parámetro (TTP, TP, INR)
            $resultTpt = LabResult::where('order_exam_id', $orderExam->id)
                ->where('parametro', 'Tiempo de Tromboplastina Parcial (TTP)')
                ->first();

            $resultTp = LabResult::where('order_exam_id', $orderExam->id)
                ->where('parametro', 'Tiempo de protombina (TP)')
                ->first();

            $resultInr = LabResult::where('order_exam_id', $orderExam->id)
                ->where('parametro', 'INR')
                ->first();

            // Combinar resultados en un objeto
            $resultadoCombinado = (object)[
                'resultado_tpt' => $resultTpt ? $resultTpt->resultado : '',
                'resultado_tp' => $resultTp ? $resultTp->resultado : '',
                'resultado_inr' => $resultInr ? $resultInr->resultado : '',
                'estado_resultado' => $resultTpt ? $resultTpt->estado_resultado : '',
                'observaciones' => $resultTpt ? $resultTpt->observaciones : '',
            ];

            $result = $resultadoCombinado;
            return view('laboratory.results.create', compact('orderExam', 'result'));
        }

        // Exámenes simples (GGT, etc.) usan el caso genérico al final

        // VIH tiene campos adicionales, mantener manejo especial
        if ($isVih) {
            // Virus Inmunodeficiencia Humana (HIV) - examen cualitativo con campos adicionales
            $result = LabResult::where('order_exam_id', $orderExam->id)
                ->where('parametro', 'Virus Inmunodeficiencia Humana (HIV)')
                ->first();

            if (!$result) {
                $result = new LabResult();
            } else {
                // Extraer campos adicionales del JSON en observaciones
                $resultadoCombinado = (object)[
                    'resultado' => $result->resultado ?? '',
                    'estado_resultado' => $result->estado_resultado ?? '',
                    'marca_reactivo' => '',
                    'metodo_prueba' => '',
                    'observaciones' => '',
                ];

                if ($result->observaciones) {
                    $observaciones = $result->observaciones;
                    if (str_contains($observaciones, '__CAMPOS_ADICIONALES__')) {
                        $parts = explode('__CAMPOS_ADICIONALES__', $observaciones);
                        $resultadoCombinado->observaciones = trim($parts[0]);
                        if (count($parts) > 1) {
                            $jsonData = json_decode($parts[1], true);
                            if ($jsonData) {
                                $resultadoCombinado->marca_reactivo = $jsonData['marca_reactivo'] ?? '';
                                $resultadoCombinado->metodo_prueba = $jsonData['metodo_prueba'] ?? '';
                            }
                        }
                    } else {
                        $resultadoCombinado->observaciones = $observaciones;
                    }
                }

                $result = $resultadoCombinado;
            }

            return view('laboratory.results.create', compact('orderExam', 'result'));
        }

        if ($isVdrlRpr) {
            // VDRL-RPR - examen cualitativo con campos adicionales
            $result = LabResult::where('order_exam_id', $orderExam->id)
                ->where('parametro', 'VDRL-RPR')
                ->first();

            if (!$result) {
                $result = new LabResult();
            } else {
                // Extraer campos adicionales del JSON en observaciones
                $resultadoCombinado = (object)[
                    'resultado' => $result->resultado ?? '',
                    'estado_resultado' => $result->estado_resultado ?? '',
                    'marca_reactivo' => '',
                    'metodo_prueba' => '',
                    'observaciones' => '',
                ];

                if ($result->observaciones) {
                    $observaciones = $result->observaciones;
                    if (str_contains($observaciones, '__CAMPOS_ADICIONALES__')) {
                        $parts = explode('__CAMPOS_ADICIONALES__', $observaciones);
                        $resultadoCombinado->observaciones = trim($parts[0]);
                        if (count($parts) > 1) {
                            $jsonData = json_decode($parts[1], true);
                            if ($jsonData) {
                                $resultadoCombinado->marca_reactivo = $jsonData['marca_reactivo'] ?? '';
                                $resultadoCombinado->metodo_prueba = $jsonData['metodo_prueba'] ?? '';
                            }
                        }
                    } else {
                        $resultadoCombinado->observaciones = $observaciones;
                    }
                }

                $result = $resultadoCombinado;
            }

            return view('laboratory.results.create', compact('orderExam', 'result'));
        }

        // Exámenes simples (VDRL Cardiolipina, etc.) usan el caso genérico al final

        // Exámenes simples (Velocidad de Eritrosedimentación, Trypanosoma Cruzi, etc.) usan el caso genérico al final

        if ($isTiroideasT3T4Tsh) {
            // Pruebas Tiroideas T3, T4, TSH - examen multi-parámetro
            $resultTsh = LabResult::where('order_exam_id', $orderExam->id)
                ->where('parametro', 'Hormona Estimulante de Tiroides (TSH)')
                ->first();

            $resultT4 = LabResult::where('order_exam_id', $orderExam->id)
                ->where('parametro', 'Tiroxina (T4)')
                ->first();

            $resultT3 = LabResult::where('order_exam_id', $orderExam->id)
                ->where('parametro', 'Triyodotironina (T3)')
                ->first();

            // Combinar resultados en un objeto
            $resultadoCombinado = (object)[
                'resultado_tsh' => $resultTsh ? $resultTsh->resultado : '',
                'estado_resultado_tsh' => $resultTsh ? $resultTsh->estado_resultado : '',
                'resultado_t4' => $resultT4 ? $resultT4->resultado : '',
                'estado_resultado_t4' => $resultT4 ? $resultT4->estado_resultado : '',
                'resultado_t3' => $resultT3 ? $resultT3->resultado : '',
                'estado_resultado_t3' => $resultT3 ? $resultT3->estado_resultado : '',
                'observaciones' => $resultTsh ? $resultTsh->observaciones : '',
            ];

            $result = $resultadoCombinado;
            return view('laboratory.results.create', compact('orderExam', 'result'));
        }

        if ($isPruebasTiroideas) {
            // Pruebas Tiroideas - examen multi-parámetro (TSH, T4, T3)
            $resultTsh = LabResult::where('order_exam_id', $orderExam->id)
                ->where('parametro', 'Hormona Estimulante de Tiroides (TSH)')
                ->first();

            $resultT4 = LabResult::where('order_exam_id', $orderExam->id)
                ->whereIn('parametro', ['Tiroxina (T4)', 'T4 Libre (FT4)'])
                ->first();

            $resultT3 = LabResult::where('order_exam_id', $orderExam->id)
                ->whereIn('parametro', ['Triyodotironina (T3)', 'T3 Libre (FT3)'])
                ->first();

            // Combinar resultados en un objeto
            $resultadoCombinado = (object)[
                'resultado_tsh' => $resultTsh ? $resultTsh->resultado : '',
                'estado_resultado_tsh' => $resultTsh ? $resultTsh->estado_resultado : '',
                'resultado_t4' => $resultT4 ? $resultT4->resultado : '',
                'estado_resultado_t4' => $resultT4 ? $resultT4->estado_resultado : '',
                'resultado_t3' => $resultT3 ? $resultT3->resultado : '',
                'estado_resultado_t3' => $resultT3 ? $resultT3->estado_resultado : '',
                'observaciones' => $resultTsh ? $resultTsh->observaciones : '',
            ];

            $result = $resultadoCombinado;
            return view('laboratory.results.create', compact('orderExam', 'result'));
        }

        // Exámenes simples (Sangre Oculta Heces, etc.) usan el caso genérico al final

        // Exámenes simples (PSA, Prolactina, B-hCG, etc.) usan el caso genérico al final

        if ($isPerfilBioquimicaClinica) {
            $results = LabResult::where('order_exam_id', $orderExam->id)
                ->whereIn('parametro', [
                    'Glucosa en Ayunas',
                    'Colesterol',
                    'Triglicéridos',
                    'Acido Úrico',
                    'Creatinina'
                ])
                ->get();

            // Crear un objeto resultado combinado para la vista
            $combinedResult = (object)[
                'resultado_glucosa_ayunas' => $results->firstWhere('parametro', 'Glucosa en Ayunas')->resultado ?? '',
                'resultado_colesterol' => $results->firstWhere('parametro', 'Colesterol')->resultado ?? '',
                'resultado_trigliceridos' => $results->firstWhere('parametro', 'Triglicéridos')->resultado ?? '',
                'resultado_acido_urico' => $results->firstWhere('parametro', 'Acido Úrico')->resultado ?? '',
                'resultado_creatinina' => $results->firstWhere('parametro', 'Creatinina')->resultado ?? '',
                'estado_resultado' => $results->first()->estado_resultado ?? '',
                'observaciones' => $results->first()->observaciones ?? null,
            ];

            $result = $combinedResult;
            return view('laboratory.results.create', compact('orderExam', 'result'));
        }

        // Proteína C Reactiva y otros exámenes simples usan el caso genérico al final

        // Prueba Azul Metileno tiene múltiples parámetros, mantener manejo especial
        if ($isPruebaAzulMetileno) {
            $results = LabResult::where('order_exam_id', $orderExam->id)
                ->whereIn('parametro', [
                    'Leucocitos Polimorfonucleares',
                    'Leucocitos Mononucleares'
                ])
                ->get();

            // Crear un objeto resultado combinado para la vista
            $combinedResult = (object)[
                'resultado_leucocitos_polimorfonucleares' => $results->firstWhere('parametro', 'Leucocitos Polimorfonucleares')->resultado ?? '',
                'resultado_leucocitos_mononucleares' => $results->firstWhere('parametro', 'Leucocitos Mononucleares')->resultado ?? '',
                'estado_resultado' => $results->first()->estado_resultado ?? '',
                'observaciones' => $results->first()->observaciones ?? null,
            ];

            $result = $combinedResult;
            return view('laboratory.results.create', compact('orderExam', 'result'));
        }

        if ($isFrotisSangrePeriferica) {
            // Extraer campos adicionales del JSON en observaciones
            $resultadoCombinado = (object)[
                'resultado' => $result->resultado ?? '',
                'estado_resultado' => $result->estado_resultado ?? '',
                'serie_roja' => '',
                'serie_blanca' => '',
                'serie_plaquetaria' => '',
                'observaciones' => '',
            ];

            if ($result->observaciones) {
                $observaciones = $result->observaciones;
                if (str_contains($observaciones, '__CAMPOS_ADICIONALES__')) {
                    $parts = explode('__CAMPOS_ADICIONALES__', $observaciones);
                    $resultadoCombinado->observaciones = trim($parts[0]);
                    if (count($parts) > 1) {
                        $jsonData = json_decode($parts[1], true);
                        if ($jsonData) {
                            $resultadoCombinado->serie_roja = $jsonData['serie_roja'] ?? '';
                            $resultadoCombinado->serie_blanca = $jsonData['serie_blanca'] ?? '';
                            $resultadoCombinado->serie_plaquetaria = $jsonData['serie_plaquetaria'] ?? '';
                        }
                    }
                } else {
                    $resultadoCombinado->observaciones = $observaciones;
                }
            }

            $result = $resultadoCombinado;
            return view('laboratory.results.create', compact('orderExam', 'result'));
        }

        if ($isBilirrubina) {
            $results = LabResult::where('order_exam_id', $orderExam->id)
                ->whereIn('parametro', ['Bilirrubina Total', 'Bilirrubina Directa', 'Bilirrubina Indirecta'])
                ->get();

            // Crear un objeto resultado combinado para la vista
            $combinedResult = (object)[
                'resultado_total' => $results->firstWhere('parametro', 'Bilirrubina Total')->resultado ?? '',
                'estado_resultado_total' => $results->firstWhere('parametro', 'Bilirrubina Total')->estado_resultado ?? '',
                'resultado_directa' => $results->firstWhere('parametro', 'Bilirrubina Directa')->resultado ?? '',
                'estado_resultado_directa' => $results->firstWhere('parametro', 'Bilirrubina Directa')->estado_resultado ?? '',
                'resultado_indirecta' => $results->firstWhere('parametro', 'Bilirrubina Indirecta')->resultado ?? '',
                'estado_resultado_indirecta' => $results->firstWhere('parametro', 'Bilirrubina Indirecta')->estado_resultado ?? '',
                'observaciones' => $results->first()->observaciones ?? null,
            ];

            $result = $combinedResult;
            return view('laboratory.results.create', compact('orderExam', 'result'));
        }

        if ($isCurvaGlucosa) {
            // Curva de Tolerancia a la Glucosa - examen multi-parámetro (4 tiempos)
            $results = LabResult::where('order_exam_id', $orderExam->id)
                ->whereIn('parametro', [
                    'Glucosa en Ayunas',
                    'Glucosa 1 Hora después de la toma',
                    'Glucosa 2 Horas después de la toma',
                    'Glucosa 3 Horas después de la toma'
                ])
                ->get();

            // Crear un objeto resultado combinado para la vista
            $combinedResult = (object)[
                'resultado_ayunas' => $results->firstWhere('parametro', 'Glucosa en Ayunas')->resultado ?? '',
                'resultado_1h' => $results->firstWhere('parametro', 'Glucosa 1 Hora después de la toma')->resultado ?? '',
                'resultado_2h' => $results->firstWhere('parametro', 'Glucosa 2 Horas después de la toma')->resultado ?? '',
                'resultado_3h' => $results->firstWhere('parametro', 'Glucosa 3 Horas después de la toma')->resultado ?? '',
                'estado_resultado' => $results->first()->estado_resultado ?? '',
                'observaciones' => $results->first()->observaciones ?? null,
            ];

            $result = $combinedResult;
            return view('laboratory.results.create', compact('orderExam', 'result'));
        }

        if ($isGlucosa) {
            $results = LabResult::where('order_exam_id', $orderExam->id)
                ->whereIn('parametro', ['Glucosa en Ayunas', 'Glucosa Post-Prandial'])
                ->get();

            // Crear un objeto resultado combinado para la vista
            $combinedResult = (object)[
                'resultado_ayunas' => $results->firstWhere('parametro', 'Glucosa en Ayunas')->resultado ?? '',
                'estado_resultado_ayunas' => $results->firstWhere('parametro', 'Glucosa en Ayunas')->estado_resultado ?? '',
                'resultado_post_prandial' => $results->firstWhere('parametro', 'Glucosa Post-Prandial')->resultado ?? '',
                'estado_resultado_post_prandial' => $results->firstWhere('parametro', 'Glucosa Post-Prandial')->estado_resultado ?? '',
                'observaciones' => $results->first()->observaciones ?? null,
            ];

            $result = $combinedResult;
            return view('laboratory.results.create', compact('orderExam', 'result'));
        }

        if ($isHemograma) {
            $results = LabResult::where('order_exam_id', $orderExam->id)
                ->whereIn('parametro', [
                    'Recuento de Globulos Blancos',
                    'Neutrófilos %',
                    'Eosinófilos %',
                    'Basófilos %',
                    'Linfocitos %',
                    'Monocitos %',
                    'Recuento de Globulos Rojos',
                    'Hematocrito',
                    'Hemoglobina',
                    'VCM',
                    'CHCM',
                    'HCM',
                    'Plaquetas'
                ])
                ->get();

            // Crear un objeto resultado combinado para la vista
            $combinedResult = (object)[
                'resultado_globulos_blancos' => $results->firstWhere('parametro', 'Recuento de Globulos Blancos')->resultado ?? '',
                'resultado_neutrofilos' => $results->firstWhere('parametro', 'Neutrófilos %')->resultado ?? '',
                'resultado_eosinofilos' => $results->firstWhere('parametro', 'Eosinófilos %')->resultado ?? '',
                'resultado_basofilos' => $results->firstWhere('parametro', 'Basófilos %')->resultado ?? '',
                'resultado_linfocitos' => $results->firstWhere('parametro', 'Linfocitos %')->resultado ?? '',
                'resultado_monocitos' => $results->firstWhere('parametro', 'Monocitos %')->resultado ?? '',
                'resultado_globulos_rojos' => $results->firstWhere('parametro', 'Recuento de Globulos Rojos')->resultado ?? '',
                'resultado_hematocrito' => $results->firstWhere('parametro', 'Hematocrito')->resultado ?? '',
                'resultado_hemoglobina' => $results->firstWhere('parametro', 'Hemoglobina')->resultado ?? '',
                'resultado_vcm' => $results->firstWhere('parametro', 'VCM')->resultado ?? '',
                'resultado_chcm' => $results->firstWhere('parametro', 'CHCM')->resultado ?? '',
                'resultado_hcm' => $results->firstWhere('parametro', 'HCM')->resultado ?? '',
                'resultado_plaquetas' => $results->firstWhere('parametro', 'Plaquetas')->resultado ?? '',
                'estado_resultado' => $results->first()->estado_resultado ?? '',
                'observaciones' => $results->first()->observaciones ?? null,
            ];

            $result = $combinedResult;
            return view('laboratory.results.create', compact('orderExam', 'result'));
        }

        if ($isHematocritoHemoglobina) {
            $results = LabResult::where('order_exam_id', $orderExam->id)
                ->whereIn('parametro', ['Hematocrito', 'Hemoglobina'])
                ->get();

            // Crear un objeto resultado combinado para la vista
            $combinedResult = (object)[
                'resultado_hematocrito' => $results->firstWhere('parametro', 'Hematocrito')->resultado ?? '',
                'estado_resultado_hematocrito' => $results->firstWhere('parametro', 'Hematocrito')->estado_resultado ?? '',
                'resultado_hemoglobina' => $results->firstWhere('parametro', 'Hemoglobina')->resultado ?? '',
                'estado_resultado_hemoglobina' => $results->firstWhere('parametro', 'Hemoglobina')->estado_resultado ?? '',
                'observaciones' => $results->first()->observaciones ?? null,
            ];

            $result = $combinedResult;
            return view('laboratory.results.create', compact('orderExam', 'result'));
        }

        if ($isHelicobacterPylori) {
            $results = LabResult::where('order_exam_id', $orderExam->id)
                ->whereIn('parametro', ['Ac. Anti-Helicobacter pylori IgG', 'Ac. Anti-Helicobacter pylori IgM'])
                ->get();

            // Crear un objeto resultado combinado para la vista
            $combinedResult = (object)[
                'resultado_igg' => $results->firstWhere('parametro', 'Ac. Anti-Helicobacter pylori IgG')->resultado ?? '',
                'estado_resultado_igg' => $results->firstWhere('parametro', 'Ac. Anti-Helicobacter pylori IgG')->estado_resultado ?? '',
                'resultado_igm' => $results->firstWhere('parametro', 'Ac. Anti-Helicobacter pylori IgM')->resultado ?? '',
                'estado_resultado_igm' => $results->firstWhere('parametro', 'Ac. Anti-Helicobacter pylori IgM')->estado_resultado ?? '',
                'observaciones' => $results->first()->observaciones ?? null,
            ];

            $result = $combinedResult;
            return view('laboratory.results.create', compact('orderExam', 'result'));
        }

        if ($isAntigenosHelicobacterPylori) {
            // Este es un examen cualitativo simple, no necesita combinación
            return view('laboratory.results.create', compact('orderExam', 'result'));
        }

        if ($isHdlLdl) {
            $results = LabResult::where('order_exam_id', $orderExam->id)
                ->whereIn('parametro', ['Colesterol de Baja Densidad (LDL)', 'Colesterol de Alta Densidad (HDL)'])
                ->get();

            // Crear un objeto resultado combinado para la vista
            $combinedResult = (object)[
                'resultado_ldl' => $results->firstWhere('parametro', 'Colesterol de Baja Densidad (LDL)')->resultado ?? '',
                'estado_resultado_ldl' => $results->firstWhere('parametro', 'Colesterol de Baja Densidad (LDL)')->estado_resultado ?? '',
                'resultado_hdl' => $results->firstWhere('parametro', 'Colesterol de Alta Densidad (HDL)')->resultado ?? '',
                'estado_resultado_hdl' => $results->firstWhere('parametro', 'Colesterol de Alta Densidad (HDL)')->estado_resultado ?? '',
                'observaciones' => $results->first()->observaciones ?? null,
            ];

            $result = $combinedResult;
            return view('laboratory.results.create', compact('orderExam', 'result'));
        }

        if ($isCoombs) {
            $results = LabResult::where('order_exam_id', $orderExam->id)
                ->whereIn('parametro', ['Coombs Indirecto', 'Coombs Directo'])
                ->get();

            // Crear un objeto resultado combinado para la vista
            $combinedResult = (object)[
                'resultado_coombs_indirecto' => $results->firstWhere('parametro', 'Coombs Indirecto')->resultado ?? '',
                'estado_resultado_coombs_indirecto' => $results->firstWhere('parametro', 'Coombs Indirecto')->estado_resultado ?? '',
                'resultado_coombs_directo' => $results->firstWhere('parametro', 'Coombs Directo')->resultado ?? '',
                'estado_resultado_coombs_directo' => $results->firstWhere('parametro', 'Coombs Directo')->estado_resultado ?? '',
                'observaciones' => $results->first()->observaciones ?? null,
            ];

            $result = $combinedResult;
            return view('laboratory.results.create', compact('orderExam', 'result'));
        }

        // CASO GENÉRICO: Para todos los exámenes simples (un solo parámetro)
        // Buscar resultado existente o crear uno nuevo
        $result = LabResult::where('order_exam_id', $orderExam->id)->first();

        if (!$result) {
            $result = new LabResult();
        }

        return view('laboratory.results.create', compact('orderExam', 'result'));
    }

    /**
     * Actualizar un resultado existente
     */
    public function update(Request $request, $resultId)
    {
        $result = LabResult::with('orderExam.exam', 'orderExam.order')->findOrFail($resultId);
        $orderExam = $result->orderExam;
        $exam = $orderExam->exam;

        // Verificar que la orden no esté autorizada
        if (in_array($orderExam->order->estado, ['completada', 'entregada'])) {
            return response()->json([
                'success' => false,
                'message' => 'No se puede editar el resultado porque la orden ya está autorizada.'
            ], 403);
        }

        // Solo definir variables para exámenes que realmente necesitan manejo especial (múltiples parámetros o campos especiales)
        $examName = strtolower($exam->nombre ?? '');
        
        // Exámenes con múltiples parámetros o campos especiales
        $isBilirrubina = $exam->template_id === 'bilirrubina' || str_contains($examName, 'bilirrubina');
        $isHdlLdl = $exam->template_id === 'hdl_ldl' || str_contains($examName, 'hdl y ldl') || (str_contains($examName, 'hdl') && str_contains($examName, 'ldl'));
        $isCoombs = $exam->template_id === 'coombs' || str_contains($examName, 'coombs');
        $isCoprocultivo = $exam->template_id === 'coprocultivo' || str_contains($examName, 'coprocultivo');
        $isFrotisSangrePeriferica = $exam->template_id === 'frotis_sangre_periferica' || str_contains($examName, 'frotis');
        $isGeneralOrina = $exam->template_id === 'general_orina' || str_contains($examName, 'general de orina') || str_contains($examName, 'orina completa');
        $isUrocultivo = $exam->template_id === 'urocultivo' || str_contains($examName, 'urocultivo');
        $isGlucosa = $exam->template_id === 'glucosa' || (str_contains($examName, 'glucosa') && (str_contains($examName, 'ayunas') || str_contains($examName, 'post-prandial')));
        $isAnticuerposTotalesHelicobacterPylori = $exam->template_id === 'anticuerpos_totales_helicobacter_pylori' || (str_contains($examName, 'anticuerpos totales helicobacter') && !str_contains($examName, 'igg') && !str_contains($examName, 'igm'));
        $isAntigenosHelicobacterPylori = $exam->template_id === 'antigenos_helicobacter_pylori' || (str_contains($examName, 'antigenos helicobacter') && (str_contains($examName, 'heces') || str_contains($examName, 'coprologia')));
        $isHelicobacterPylori = $exam->template_id === 'helicobacter_pylori' || (str_contains($examName, 'helicobacter') && (str_contains($examName, 'igg') || str_contains($examName, 'igm')));
        $isToxoplasmaGondii = $exam->template_id === 'toxoplasma_gondii' || (str_contains($examName, 'toxoplasma') && (str_contains($examName, 'igg') || str_contains($examName, 'igm')));
        $isCurvaGlucosa = $exam->template_id === 'curva_tolerancia_glucosa' || str_contains($examName, 'curva tolerancia glucosa');
        $isTptTp = $exam->template_id === 'tpt_tp' || str_contains($examName, 'tpt y tp') || str_contains($examName, 'tpt tp');
        $isTiroideasT3T4Tsh = $exam->template_id === 'tiroideas_t3_t4_tsh' || (str_contains($examName, 'tiroideas') && str_contains($examName, 't3') && str_contains($examName, 't4') && str_contains($examName, 'tsh'));
        $isPruebasTiroideas = $exam->template_id === 'pruebas_tiroideas' || str_contains($examName, 'pruebas tiroideas');
        $isVih = $exam->template_id === 'vih' || str_contains($examName, 'vih') || str_contains($examName, 'virus inmunodeficiencia');
        $isVdrlRpr = $exam->template_id === 'vdrl_rpr' || (str_contains($examName, 'vdrl') && str_contains($examName, 'rpr'));
        $isVdrlCardiolipina = $exam->template_id === 'vdrl_cardiolipina' || (str_contains($examName, 'vdrl') && str_contains($examName, 'cardiolipina'));
        $isPerfilBioquimicaClinica = $exam->template_id === 'perfil_bioquimica_clinica' || str_contains($examName, 'perfil bioquimica clinica');
        $isHemograma = $exam->template_id === 'hemograma' || str_contains($examName, 'hemograma') || str_contains($examName, 'hematologia completa');
        $isHematocritoHemoglobina = $exam->template_id === 'hematocrito_hemoglobina' || (str_contains($examName, 'hematocrito') && str_contains($examName, 'hemoglobina'));
        $isTestOsullivan = $exam->template_id === 'test_osullivan' || str_contains($examName, 'osullivan');
        $isAntigenosFebriles = $exam->template_id === 'antigenos_febriles' || str_contains($examName, 'antigenos febriles');
        $isAcidoValproico = $exam->template_id === 'acido_valproico' || str_contains($examName, 'acido valproico');
        $isAmilasaLipasa = $exam->template_id === 'amilasa_lipasa' || (str_contains($examName, 'amilasa') && str_contains($examName, 'lipasa'));
        $isDepuracionCreatinina = $exam->template_id === 'depuracion_creatinina' || str_contains($examName, 'depuracion creatinina');

        $isSangreOcultaHeces = $exam->template_id === 'sangre_oculta_heces'
            || str_contains($examName, 'sangre oculta en heces')
            || str_contains($examName, 'sangre oculta heces')
            || (str_contains($examName, 'sangre oculta') && str_contains($examName, 'heces'))
            || str_contains($examName, 'fecal occult blood');

        $isPsaTotal = $exam->template_id === 'psa_total'
            || str_contains($examName, 'antigeno prostatico especifico total')
            || str_contains($examName, 'antígeno prostático específico total')
            || str_contains($examName, 'psa total')
            || (str_contains($examName, 'psa') && str_contains($examName, 'total'))
            || str_contains($examName, 'prostate specific antigen');

        $isProteinasOrinaAzar = $exam->template_id === 'proteinas_orina_azar'
            || str_contains($examName, 'proteinas en orina al azar')
            || str_contains($examName, 'proteínas en orina al azar')
            || (str_contains($examName, 'proteinas') && str_contains($examName, 'orina') && str_contains($examName, 'azar'));

        $isGeneralOrina = $exam->template_id === 'general_orina'
            || str_contains($examName, 'general de orina')
            || str_contains($examName, 'orina completa');

        $isHemograma = $exam->template_id === 'hemograma'
            || str_contains($examName, 'hemograma')
            || str_contains($examName, 'hematologia completa')
            || str_contains($examName, 'hematología completa');

        $isHematocritoHemoglobina = $exam->template_id === 'hematocrito_hemoglobina'
            || (str_contains($examName, 'hematocrito') && str_contains($examName, 'hemoglobina'))
            || str_contains($examName, 'hematocrito y hemoglobina');

        $isHemoglobinaGlicosilada = $exam->template_id === 'hemoglobina_glicosilada'
            || str_contains($examName, 'hemoglobina glicosilada')
            || str_contains($examName, 'hemoglobina glicosilada a1c')
            || str_contains($examName, 'hba1c')
            || str_contains($examName, 'hemoglobin a1c');

        $isDepuracionCreatinina = $exam->template_id === 'depuracion_creatinina'
            || str_contains($examName, 'depuracion de creatinina')
            || str_contains($examName, 'depuración de creatinina')
            || str_contains($examName, 'depuracion creatinina');

        if ($isAcidoValproico) {
            $validated = $request->validate([
                'resultado' => 'required|numeric',
                'estado_resultado' => 'required|in:normal,alto,bajo,critico',
                'observaciones' => 'nullable|string',
            ]);

            // Actualizar resultado para Ácido Valpróico
            $valoresRef = $exam->valores_referencia_especificos ?? [];

            // Si no hay valores en el examen, usar los del template
            if (empty($valoresRef) || !isset($valoresRef['valores_referencia'])) {
                $template = config('lab_exam_templates.acido_valproico');
                $valoresRef = $template['valores_referencia'] ?? [];
            } else {
                $valoresRef = $valoresRef['valores_referencia'] ?? $valoresRef;
            }

            $unidad = $exam->valores_referencia_especificos['unidad_medida'] ?? config('lab_exam_templates.acido_valproico.unidad_medida', 'ug/mL');
